{
  "extends": [
    "config:base"
  ],
  "onboarding":     false
  ,
  "rangeStrategy": "replace",
  "semanticCommits": "enabled",
  "timezone": "US/Central",
  "baseBranches": [
    "main"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "helm"
      ],
      "extractVersion": "^v(?<version>.*)$"
    }
  ],
  "lockFileMaintenance": {
    "enabled": false
  }
}
