{
  "extends": [
    ":maintainLockFilesDisabled"
  ],
  "onboarding": false,
  "rangeStrategy": "replace",
  "semanticCommits": "enabled",
  "timezone": "US/Central",
  "baseBranches": [
    "main"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "helm"
      ],
      "extractVersion": "^v(?<version>.*)$"
    }
  ]
}
